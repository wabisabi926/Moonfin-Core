ENV['COCOAPODS_DISABLE_STATS'] = 'true'

platform :ios, '15.0'

source 'https://cdn.cocoapods.org/'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

def patch_media_kit_video_ios_pip_bridge
  plugin_root = File.expand_path(File.join('.symlinks', 'plugins', 'media_kit_video'), __dir__)
  return unless File.directory?(plugin_root)

  patches = [
    {
      path: File.join(plugin_root, 'ios', 'Classes', 'plugin', 'TextureHW.swift'),
      marker: 'org.moonfin.ios/pip_shared_frames.frame',
      needle: "    textureContexts.pushAsReady(textureContext!)\n",
      insert: <<~'SWIFT'
        NotificationCenter.default.post(
          name: .init("org.moonfin.ios/pip_shared_frames.frame"),
          object: nil,
          userInfo: ["pixelBuffer": textureContext!.pixelBuffer]
        )

      SWIFT
    },
    {
      path: File.join(plugin_root, 'ios', 'Classes', 'plugin', 'common', 'TextureSW.swift'),
      marker: 'org.moonfin.ios/pip_shared_frames.frame',
      needle: "    textureContexts.pushAsReady(textureContext!)\n",
      insert: <<~'SWIFT'
        #if os(iOS)
          NotificationCenter.default.post(
            name: .init("org.moonfin.ios/pip_shared_frames.frame"),
            object: nil,
            userInfo: ["pixelBuffer": textureContext!.pixelBuffer]
          )
        #endif

      SWIFT
    },
  ]

  patches.each do |patch|
    next unless File.exist?(patch[:path])

    content = File.read(patch[:path])
    next if content.include?(patch[:marker])

    unless content.include?(patch[:needle])
      # Fail the build loudly. A silent skip here ships a black iOS PiP window because
      # nothing else feeds frames to the AVSampleBufferDisplayLayer. If media_kit_video
      # was upgraded and the anchor moved, update :needle rather than removing this.
      raise "moonfin: iOS PiP bridge patch failed, anchor not found in #{patch[:path]}. " \
            "media_kit_video source changed; update the needle in " \
            "patch_media_kit_video_ios_pip_bridge or PiP will ship black."
    end

    File.write(patch[:path], content.sub(patch[:needle], patch[:needle] + patch[:insert]))
    Pod::UI.puts("moonfin: Applied iOS PiP bridge patch to #{patch[:path]}")
  end
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  patch_media_kit_video_ios_pip_bridge
  pod 'google-cast-sdk-no-bluetooth-xcframework', '~> 4.8.0'
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
